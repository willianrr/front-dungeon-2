# --- Frontend (Vite) ---
# Apenas variaveis com prefixo VITE_ sao expostas ao navegador.
# NUNCA coloque segredos aqui (senha de banco, JWT_SECRET, etc.) — isso vai
# para dentro do bundle do cliente. Aqui entra so a URL publica do backend.

# REST do backend (accounts, characters, items, status)
VITE_API_URL=http://localhost:8080/api/v1

# WebSocket do servidor de jogo (drop autoritativo / futura simulacao)
VITE_WS_URL=ws://localhost:8080/ws/game
